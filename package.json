{
  "name": "@get401/node",
  "version": "0.1.0",
  "description": "Core Node.js SDK for get401 authentication — EdDSA/Ed25519 JWT verification.",
  "keywords": [
    "get401",
    "authentication",
    "jwt",
    "eddsa",
    "ed25519",
    "auth",
    "node"
  ],
  "license": "MIT",
  "homepage": "https://get401.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/get401/js-node"
  },
  "bugs": "https://github.com/get401/js-node/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "jose": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18"
  }
}
